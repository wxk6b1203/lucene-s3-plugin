<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">
    <property name="LOG_LEVEL" value="${LUCENE_S3_LOG_LEVEL:-INFO}"/>
    <property name="LOG_DIR" value="${LUCENE_S3_LOG_DIR:-logs}"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{48} - %msg%n"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <target>System.out</target>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/lucene-s3.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/lucene-s3.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LUCENE_S3_LOG_MAX_FILE_SIZE:-100MB}</maxFileSize>
            <maxHistory>${LUCENE_S3_LOG_MAX_HISTORY:-14}</maxHistory>
            <totalSizeCap>${LUCENE_S3_LOG_TOTAL_SIZE_CAP:-2GB}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
